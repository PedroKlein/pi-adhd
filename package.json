{
  "name": "pi-adhd",
  "version": "0.1.0",
  "description": "Attention management for Pi — sticky notes, side-chat, and reminders",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "keywords": [
    "pi-package",
    "pi",
    "adhd",
    "attention",
    "sticky-notes",
    "side-chat",
    "coding-agent"
  ],
  "license": "MIT",
  "author": "",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "^0.78.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
